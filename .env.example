# Which LLM provider the agent uses: "anthropic" or "openai".
LLM_PROVIDER=anthropic

# Provide a key for the provider you selected above.
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Guardrails (see docs/HARDENING.md). All optional; defaults shown. ---

# Maximum characters per customer message (HTTP 400 if exceeded).
# MAX_MESSAGE_CHARS=2000

# Maximum messages allowed in a single conversation (HTTP 429 after that;
# customer is asked to start a new chat).
# MAX_CONVERSATION_TURNS=30

# Cumulative LLM-token budget per conversation. Once exceeded, the next turn
# refuses politely without calling the model.
# MAX_CONVERSATION_TOKENS=60000

# Hard cap on the LangGraph tool-call loop for a single turn.
# AGENT_RECURSION_LIMIT=12

# Per-response output cap passed to the chat model.
# MAX_OUTPUT_TOKENS=1024

# Per-IP rate limit on POST /api/chat (slowapi format).
# CHAT_RATE_LIMIT=10/minute
